# Copy this file to .env and fill in real values. .env is gitignored and
# should never be committed.

# Google Books API key (Google Cloud Console -> APIs & Services -> Credentials).
# Required for reliable book discovery -- without it, Google Books falls back
# to a small shared anonymous quota that gets rate-limited quickly.
GOOGLE_BOOKS_API_KEY=

# Hardcover.app API token (hardcover.app -> account settings -> API).
# Optional but recommended -- Hardcover has much better coverage of
# indie/self-published LitRPG titles than Google Books/OpenLibrary, and its
# search results include an explicit series-position field, which is a more
# reliable source of a book's number than parsing it out of the title text.
# Marked "experimental" by Hardcover; if it starts failing consistently,
# discovery still works fine on Google Books + OpenLibrary alone.
HARDCOVER_API_KEY=

# --- Access control (required once this is deployed publicly) ---------

# Your personal login password for full read/write access. Choose your own
# value -- there is no default, and the app will refuse logins until this
# is set.
OWNER_PASSWORD=

# Random signing key for owner login tokens. Generate a strong random value
# once (e.g. `python -c "import secrets; print(secrets.token_urlsafe(32))"`)
# and never change it casually -- changing it invalidates all existing
# logins.
AUTH_SECRET_KEY=

# A separate random token that grants read-only "viewer" access when
# present in the URL as ?share=<token> (no password needed). Anyone with
# this token/link can view the library but cannot add, edit, or delete
# anything -- that's enforced by the server, not just hidden in the UI.
# Generate the same way as AUTH_SECRET_KEY, with a different value.
SHARE_VIEW_TOKEN=

# --- Deployment ---------------------------------------------------------

# Where the SQLite file lives. Leave unset for local dev (defaults to
# ./books.db in the project folder). On Render/Railway, set this to a path
# inside your mounted persistent disk/volume, e.g. /data/books.db -- so the
# database survives restarts and redeploys instead of resetting each time.
DATABASE_PATH=
