# Copy this file to .env and fill in real values. .env is gitignored and
# should never be committed.

# Google Books API key (Google Cloud Console -> APIs & Services -> Credentials).
# Required for reliable book discovery -- without it, Google Books falls back
# to a small shared anonymous quota that gets rate-limited quickly.
GOOGLE_BOOKS_API_KEY=

# Set to 1/true to enable the automatic daily background scan of all series.
# Off by default so discovery API calls only happen when you trigger them.
ENABLE_DAILY_SERIES_SCAN=
